# Copy to .env and set your values.

# Required for embeddings (and for QA if not using a local LLM).
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# LLM for QA: default is local GGUF at models/Qwen2.5-0.5B-Instruct-GGUF.gguf
# - Unset or comment out → use default path (fallback to OpenAI if file missing)
# - Set to a path → use that GGUF file
# - Set to "hf:repo_id" or "hf:repo_id:filename" → download from Hugging Face and use create_chat_completion
# - Set to empty or "openai" → use OpenAI for QA
LLM_MODEL_PATH=./models/Qwen2.5-0.5B-Instruct-GGUF.gguf
# LLM_MODEL_PATH=hf:Qwen/Qwen2.5-0.5B-Instruct-GGUF
# LLM_MODEL_PATH=openai
